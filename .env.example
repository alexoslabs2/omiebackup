OMIE_APP_KEY=
OMIE_APP_SECRET=
OMIE_PROFILE_NAME=

# Optional multi-account mode. When set, the script backs up every listed profile
# in one run using OMIE_PROFILE_<NAME>_APP_KEY/SECRET variables.
# Profile names may contain letters, numbers, underscores, and hyphens.
OMIE_PROFILES=
OMIE_PROFILE_CLIENT_A_APP_KEY=
OMIE_PROFILE_CLIENT_A_APP_SECRET=
OMIE_PROFILE_CLIENT_B_APP_KEY=
OMIE_PROFILE_CLIENT_B_APP_SECRET=

BACKUP_MODE=incremental

STORAGE_TYPE=local
STORAGE_LOCAL_PATH=backups

AWS_S3_BUCKET=
AWS_S3_PREFIX=omie-backup
AWS_REGION=sa-east-1

SFTP_HOST=
SFTP_PORT=22
SFTP_USERNAME=
SFTP_KEY_FILE=
SFTP_REMOTE_PATH=/omie-backup

API_DELAY_MS=300
API_MAX_RETRIES=3
API_TIMEOUT_SECONDS=30
API_RECORDS_PER_PAGE=50

ALERT_ENABLED=false
ALERT_ON_SUCCESS=false
ALERT_MAX_DURATION_HOURS=4
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURITY=starttls
SMTP_TLS=true
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=

LOG_LEVEL=INFO
OUTPUT_DIR=backups
